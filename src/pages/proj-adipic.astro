html.reveal-ready .animate-blog-1 { animation: blurSlideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; }
html.reveal-ready .animate-blog-2 { animation: blurSlideUp 0.8s cubic-bezier(0.2, 0.8, 0.2, 1) forwards; animation-delay: 0.15s; }
