@media (max-width: 768px) { .nav, .proj-nav { padding: 1rem 1.5rem; } .nav-status { display: none; } .hero, .about, .works, .contact, .proj-header, .proj-body, .demo-zone { padding-left: 1.5rem; padding-right: 1.5rem; } .about { grid-template-columns: 1fr; gap: 2.5rem; } .human-row { grid-template-columns: 1fr; gap: 0.25rem; padding: 1rem 0; } .proj-grid { grid-template-columns: 1fr; } .proj-tile.wide, .proj-tile.full { grid-column: span 1; aspect-ratio: 16/10; } .hero-title { font-size: clamp(40px, 10vw, 52px); } .proj-page-title { font-size: clamp(32px, 8vw, 48px); } .contact-row { flex-wrap: wrap; gap: 0.5rem; } }
*{box-sizing:border-box;margin:0;padding:0;}
html{scroll-behavior:smooth;}
:root{ --bg:#0d0d0d; --bg1:#141414; --bg2:#1c1c1c; --text:#f0efeb; --muted:#888; --dim:#444; --green:#22c55e; --border:rgba(255,255,255,0.08); --border2:rgba(255,255,255,0.14); --ff:'Space Grotesk',system-ui,sans-serif; --fi:'Playfair Display',Georgia,serif; }
