<script is:inline>
  let isMale = true;

  function updateSliderUI(type) {
    if(type === 'bw') {
      document.getElementById('bw-val').innerText = document.getElementById('bw-slider').value;
    }
    if(type === 'age') {
      document.getElementById('age-val').innerText = document.getElementById('age-slider').value;
    }
    
    const sliders = document.querySelectorAll('.premium-slider');
    sliders.forEach(slider => {
      const min = slider.min || 0;
      const max = slider.max || 100;
      const val = slider.value;
      const percentage = ((val - min) / (max - min)) * 100;
      slider.style.background = `linear-gradient(to right, rgba(255,255,255,0.6) ${percentage}%, rgba(255,255,255,0.1) ${percentage}%)`;
    });
  }

  function setSex(sex) {
    isMale = (sex === 'male');
    document.getElementById('btn-male').className = isMale ? 'seg-btn active' : 'seg-btn';
    document.getElementById('btn-female').className = !isMale ? 'seg-btn active' : 'seg-btn';
  }

  function runCalculation() {
    const board = document.getElementById('output-board');
    board.classList.remove('empty-state');
    document.getElementById('status-text').innerText = "Model Executed successfully";
    document.getElementById('out-kg').style.opacity = 1;

    document.getElementById('scene-sq').classList.add('active-sq');
    document.getElementById('scene-bn').classList.add('active-bn');
    document.getElementById('scene-dl').classList.add('active-dl');

    const bw = parseFloat(document.getElementById('bw-slider').value);
    const age = parseFloat(document.getElementById('age-slider').value);

    const sex_enc = isMale ? 1 : 0;
    const equipment_enc = 1; 
    const year = new Date().getFullYear(); 
    
    // NOTE: If you still get 'NaN' after hitting calculate, it means your Python model 
    // expects more than just these 5 columns. You must add the extra 0s to this array.
    const features = [sex_enc, equipment_enc, bw, age, year];

    let predicted_total = 0;
    
    try {
      // FIX APPLIED HERE: Changed from score(features) to predictTotal(features)
      predicted_total = predictTotal(features); 
    } catch (e) {
      console.error("Machine Learning Error", e);
      document.getElementById('out-total').innerText = "ERR";
      return;
    }
    
    // Safety check if the feature array length is wrong
    if (isNaN(predicted_total)) {
      document.getElementById('out-total').innerText = "NaN";
      return;
    }

    predicted_total = Math.round(predicted_total);

    const sqRatio = isMale ? 0.356 : 0.363;
    const bnRatio = isMale ? 0.232 : 0.200;
    const dlRatio = isMale ? 0.411 : 0.435;

    const totalVariance = Math.round(predicted_total * 0.134);
    
    const sqVar = Math.round(totalVariance * sqRatio);
    const bnVar = Math.round(totalVariance * bnRatio);
    const dlVar = Math.round(totalVariance * dlRatio);

    document.getElementById('out-total').innerText = predicted_total;
    const lowerBound = predicted_total - totalVariance;
    const upperBound = predicted_total + totalVariance;
    document.getElementById('out-var').innerText = `${lowerBound}kg – ${upperBound}kg (±${totalVariance}kg)`;
    
    document.getElementById('out-sq').innerText = Math.round(predicted_total * sqRatio) + ' kg';
    document.getElementById('var-sq').innerText = `±${sqVar} kg`;

    document.getElementById('out-bn').innerText = Math.round(predicted_total * bnRatio) + ' kg';
    document.getElementById('var-bn').innerText = `±${bnVar} kg`;

    document.getElementById('out-dl').innerText = Math.round(predicted_total * dlRatio) + ' kg';
    document.getElementById('var-dl').innerText = `±${dlVar} kg`;
  }

  window.addEventListener('load', () => {
    document.documentElement.classList.add('reveal-ready');
    updateSliderUI('bw');
    updateSliderUI('age');
  });
</script>

