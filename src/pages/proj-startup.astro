.proj-overlay{position:absolute;inset:0;background:rgba(13,13,13,0);display:flex;align-items:center;justify-content:center;transition:background .3s;}
.proj-tile:hover .proj-overlay{background:rgba(13,13,13,0.5);}
.view-pill{ font-size:12px;letter-spacing:.1em;text-transform:uppercase;font-weight:500; color:var(--text);opacity:0;border:1px solid rgba(255,255,255,0.25); padding:.5rem 1.3rem;border-radius:100px;transition:opacity .3s; }
