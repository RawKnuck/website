.t-startup{background:radial-gradient(ellipse at 30% 70%,#1a1108 0%,#0d0d0d 100%);}
.t-power{background:radial-gradient(ellipse at 50% 40%,#0f0f1f 0%,#0d0d0d 100%);}
.t-chem2{background:radial-gradient(ellipse at 60% 60%,#0a140f 0%,#0d0d0d 100%);}
.t-ai{background:radial-gradient(ellipse at 50% 50%,#110e1a 0%,#0d0d0d 100%);}
.t-blog1{background:radial-gradient(ellipse at 80% 20%,#1a0e10 0%,#0d0d0d 100%);}
.t-blog2{background:radial-gradient(ellipse at 20% 80%,#0e141a 0%,#0d0d0d 100%);}
