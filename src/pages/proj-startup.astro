.b-desc { font-size: 14px; color: rgba(240,239,235,0.9); line-height: 1.6; flex: 1; }
.b-desc em { font-style: normal; color: var(--muted); font-size: 12px; }
@media (max-width: 768px) { .bento-hobbies { grid-template-columns: 1fr; } .b-senses { grid-column: span 1; flex-direction: column; align-items: flex-start; gap: 0.5rem; } .b-title { min-width: auto; } }
@keyframes blurSlideDown { 0% { opacity: 0; transform: translateY(-20px); filter: blur(10px); } 100% { opacity: 1; transform: translateY(0); filter: blur(0); } }
@keyframes blurSlideUp { 0% { opacity: 0; transform: translateY(20px); filter: blur(10px); } 100% { opacity: 1; transform: translateY(0); filter: blur(0); } }
.animate-pill, .animate-text-1, .animate-text-2, .animate-blog-1, .animate-blog-2 { opacity: 0; will-change: transform, opacity, filter; }
